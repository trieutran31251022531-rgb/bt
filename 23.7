import osmnx as ox
import networkx as nx
import folium
place = "District 1, Ho Chi Minh City, Vietnam"
G = ox.graph_from_place(place, network_type="drive")
point_A = (10.7769, 106.7009) 
point_B = (10.7880, 106.6950) 
orig = ox.distance.nearest_nodes(G, point_A[1], point_A[0])
dest = ox.distance.nearest_nodes(G, point_B[1], point_B[0])

route_dijkstra = nx.shortest_path(G, orig, dest, weight="length")
length_dijkstra = nx.shortest_path_length(G, orig, dest, weight="length")

def heuristic(u, v):
    y1, x1 = G.nodes[u]['y'], G.nodes[u]['x']
    y2, x2 = G.nodes[v]['y'], G.nodes[v]['x']
    return ((y1 - y2)**2 + (x1 - x2)**2)**0.5

route_astar = nx.astar_path(G, orig, dest, heuristic=heuristic, weight="length")
length_astar = nx.astar_path_length(G, orig, dest, heuristic=heuristic, weight="length")

print("=== Dijkstra ===")
print(f"Chiều dài: {length_dijkstra:.2f} m")

print("\n=== A* ===")
print(f"Chiều dài: {length_astar:.2f} m")
m = folium.Map(location=point_A, zoom_start=14)
def plot_route(route, color):
    coords = [(G.nodes[n]['y'], G.nodes[n]['x']) for n in route]
    folium.PolyLine(coords, color=color, weight=5).add_to(m)

plot_route(route_dijkstra, "blue")
plot_route(route_astar, "red")

folium.Marker(point_A, popup="Start", icon=folium.Icon(color="green")).add_to(m)
folium.Marker(point_B, popup="End", icon=folium.Icon(color="red")).add_to(m)
m
